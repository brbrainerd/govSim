# IG 2.0 GBNF grammar for llama.cpp constrained decoding.
# Constrains LLM output to valid IgStatement JSON.
# Generated by hand from data/grammars/ig2_schema.json; update when ig2.rs changes.

root ::= ig-statement

ig-statement ::= "{" ws
  "\"statement_type\"" ws ":" ws statement-type "," ws
  "\"subject\"" ws ":" ws string "," ws
  "\"deontic\"" ws ":" ws deontic "," ws
  "\"aim\"" ws ":" ws string "," ws
  "\"object\"" ws ":" ws string "," ws
  "\"conditions\"" ws ":" ws conditions "," ws
  "\"exceptions\"" ws ":" ws exceptions "," ws
  "\"computation\"" ws ":" ws computation
ws "}"

statement-type ::= "\"regulative\"" | "\"constitutive\""

deontic ::= "\"must\"" | "\"must_not\"" | "\"may\"" | "\"should\"" | "\"should_not\""

conditions ::= "[" ws "]"
  | "[" ws string (ws "," ws string)* ws "]"

exceptions ::= "[" ws "]"
  | "[" ws string (ws "," ws string)* ws "]"

computation ::= bracketed-tax | flat-rate | means-tested | registration | conditional-transfer

bracketed-tax ::= "{" ws
  "\"type\"" ws ":" ws "\"BracketedTax\"" "," ws
  "\"scope\"" ws ":" ws string "," ws
  "\"brackets\"" ws ":" ws brackets
ws "}"

brackets ::= "[" ws bracket (ws "," ws bracket)* ws "]"

bracket ::= "{" ws
  "\"floor\"" ws ":" ws number "," ws
  "\"ceiling\"" ws ":" ws (number | "null") "," ws
  "\"rate\"" ws ":" ws number
ws "}"

flat-rate ::= "{" ws
  "\"type\"" ws ":" ws "\"FlatRate\"" "," ws
  "\"scope\"" ws ":" ws string "," ws
  "\"rate\"" ws ":" ws number "," ws
  "\"cadence\"" ws ":" ws cadence
ws "}"

means-tested ::= "{" ws
  "\"type\"" ws ":" ws "\"MeansTestedBenefit\"" "," ws
  "\"scope\"" ws ":" ws string "," ws
  "\"income_ceiling\"" ws ":" ws number "," ws
  "\"taper_rate\"" ws ":" ws number "," ws
  "\"max_benefit\"" ws ":" ws number "," ws
  "\"cadence\"" ws ":" ws cadence
ws "}"

registration ::= "{" ws
  "\"type\"" ws ":" ws "\"RegistrationRequirement\"" "," ws
  "\"scope\"" ws ":" ws string "," ws
  "\"threshold\"" ws ":" ws number
ws "}"

conditional-transfer ::= "{" ws
  "\"type\"" ws ":" ws "\"ConditionalTransfer\"" "," ws
  "\"scope\"" ws ":" ws string "," ws
  "\"eligibility_basis\"" ws ":" ws string "," ws
  "\"ceiling\"" ws ":" ws (number | "null") "," ws
  "\"floor\"" ws ":" ws (number | "null") "," ws
  "\"amount\"" ws ":" ws number "," ws
  "\"cadence\"" ws ":" ws cadence
ws "}"

cadence ::= "\"monthly\"" | "\"quarterly\"" | "\"yearly\""

# primitives
string  ::= "\"" char* "\""
char    ::= [^"\\] | "\\" (["\\/bfnrt] | "u" [0-9a-fA-F] [0-9a-fA-F] [0-9a-fA-F] [0-9a-fA-F])
number  ::= "-"? ([0-9] | [1-9][0-9]+) ("." [0-9]+)? (([eE] [-+]? [0-9]+))?
ws      ::= ([ \t\n\r]*)
