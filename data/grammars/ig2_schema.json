  "definitions": {
    "ActorRef": {
      "type": "object",
      "required": [
        "class"
      ],
      "properties": {
        "class": {
          "description": "Class name (e.g. \"individual\", \"treasury\", \"legislator\").",
          "type": "string"
        },
        "qualifier": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "AmountBasis": {
      "oneOf": [
        {
          "description": "Citizen's daily Income × 360 → annualized.",
          "type": "string",
          "enum": [
            "annual_income"
          ]
        },
        {
          "description": "Citizen's Wealth (point-in-time).",
          "type": "string",
          "enum": [
            "wealth"
          ]
        }
      ]
    },
    "Computation": {
      "description": "Structured computation payloads. The LLM extractor will emit one of these inside an XGrammar-constrained JSON envelope; for now hand-authors can write them directly. Adding a variant here means: (a) the parser accepts it, (b) the lowering pass must learn to compile it.",
      "oneOf": [
        {
          "description": "Piecewise-linear bracketed rate applied to a basis (e.g. annual income). Brackets must be sorted by ascending `floor`.",
          "type": "object",
          "required": [
            "basis",
            "brackets",
            "cadence",
            "kind",
            "threshold"
          ],
          "properties": {
            "basis": {
              "$ref": "#/definitions/AmountBasis"
            },
            "brackets": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/TaxBracket"
              }
            },
            "cadence": {
              "$ref": "#/definitions/LowerCadence"
            },
            "kind": {
              "type": "string",
              "enum": [
                "bracketed_tax"
              ]
            },
            "threshold": {
              "type": "number",
              "format": "double"
            }
          }
        },
        {
          "description": "Single rate applied to the basis when above threshold.",
          "type": "object",
          "required": [
            "basis",
            "cadence",
            "kind",
            "rate",
            "threshold"
          ],
          "properties": {
            "basis": {
              "$ref": "#/definitions/AmountBasis"
            },
            "cadence": {
              "$ref": "#/definitions/LowerCadence"
            },
            "kind": {
              "type": "string",
              "enum": [
                "flat_rate"
              ]
            },
            "rate": {
              "type": "number",
              "format": "double"
            },
            "threshold": {
              "type": "number",
              "format": "double"
            }
          }
        },
        {
          "description": "Means-tested transfer payment. Citizens whose `basis` is below `income_ceiling` receive a flat `amount` each cadence period. The payment is reduced linearly from `amount` to zero between `taper_floor` and `income_ceiling` when `taper_floor` is Some.",
          "type": "object",
          "required": [
            "amount",
            "basis",
            "cadence",
            "income_ceiling",
            "kind"
          ],
          "properties": {
            "amount": {
              "description": "Gross benefit amount per period.",
              "type": "number",
              "format": "double"
            },
            "basis": {
              "$ref": "#/definitions/AmountBasis"
            },
            "cadence": {
              "$ref": "#/definitions/LowerCadence"
            },
            "income_ceiling": {
              "description": "Citizens above this income receive nothing.",
              "type": "number",
              "format": "double"
            },
            "kind": {
              "type": "string",
              "enum": [
                "means_tested_benefit"
              ]
            },
            "taper_floor": {
              "description": "Full-benefit ceiling: if Some, benefit tapers between this and `income_ceiling`. If None, full `amount` is paid below ceiling.",
              "type": [
                "number",
                "null"
              ],
              "format": "double"
            }
          }
        },
        {
          "description": "Non-monetary obligation: marks citizens who satisfy `condition_basis` below/above `threshold` as requiring registration (sets a flag). Lowering emits a no-op DSL scope; the effect is modeled through `LegalStatuses` directly in the dispatcher.",
          "type": "object",
          "required": [
            "basis",
            "cadence",
            "kind",
            "threshold"
          ],
          "properties": {
            "basis": {
              "$ref": "#/definitions/AmountBasis"
            },
            "cadence": {
              "$ref": "#/definitions/LowerCadence"
            },
            "kind": {
              "type": "string",
              "enum": [
                "registration_requirement"
              ]
            },
            "threshold": {
              "description": "Threshold below which registration is required.",
              "type": "number",
              "format": "double"
            }
          }
        },
        {
          "description": "One-time or recurring conditional transfer (stimulus / UBI slice). Citizens whose `basis` is strictly below `wealth_ceiling` receive `amount` from the Treasury. No taper — cliff at `wealth_ceiling`. Optionally conditional on `income_floor` ≤ income (e.g. working-poor supplement) when `income_floor` is Some.",
          "type": "object",
          "required": [
            "amount",
            "cadence",
            "ceiling",
            "eligibility_basis",
            "kind"
          ],
          "properties": {
            "amount": {
              "description": "Transfer amount per period.",
              "type": "number",
              "format": "double"
            },
            "cadence": {
              "$ref": "#/definitions/LowerCadence"
            },
            "ceiling": {
              "description": "Citizens with basis below this receive the payment.",
              "type": "number",
              "format": "double"
            },
            "eligibility_basis": {
              "description": "Which basis determines eligibility.",
              "allOf": [
                {
                  "$ref": "#/definitions/AmountBasis"
                }
              ]
            },
            "floor": {
              "description": "Optional lower bound on the same basis for eligibility.",
              "type": [
                "number",
                "null"
              ],
              "format": "double"
            },
            "kind": {
              "type": "string",
              "enum": [
                "conditional_transfer"
              ]
            }
          }
        }
      ]
    },
