                },
                "indirect_object_property": {
                  "default": null,
                  "anyOf": [
                    {
                      "$ref": "#/definitions/Predicate"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "regulative"
                  ]
                },
                "or_else": {
                  "description": "Consequence (O): or-else clause.",
                  "default": null,
                  "anyOf": [
                    {
                      "$ref": "#/definitions/IgStatement"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            },
            {
